#version 460
// BENCH VARIANT of pom_walk.comp — byte-identical RESULT, but each invocation walks G=4
// INDEPENDENT nonces interleaved. The walk is a serial dependent-read chain, so one nonce/thread
// leaves a thread with a single outstanding VRAM read at a time; interleaving G nonces gives G
// independent reads per step → G× memory-level parallelism per thread, which is the lever for a
// latency-bound random-access kernel (the modulo/wave-width variants showed ALU isn't the limit).
// Costs registers (G states + G offsets), which lowers occupancy — the bench finds the sweet spot.
// local_size_x = 64, hardware `%` (baseline math) so ILP is the ONLY variable. `bench` feature only.
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_buffer_reference : require

layout(local_size_x = 64) in;

const uint G = 4u; // independent nonces per invocation

layout(std430, buffer_reference, buffer_reference_align = 8) readonly buffer Shard {
    uint64_t words[];
};

layout(std430, binding = 0) buffer Winner { uint offset; } OUT;
layout(std430, binding = 1) readonly buffer ShardAddrs { uint64_t addr[]; } SHARDS;

layout(push_constant) uniform Push {
    uint64_t p0, p1, p2, p3;
    uint64_t t0, t1, t2, t3;
    uint64_t timestamp;
    uint64_t n_chunks;
    uint64_t start_nonce;
    uint64_t shard_mask;
    uint k;
    uint batch;
    uint shard_shift;
} pc;

uint64_t mix64(uint64_t x) {
    x ^= x >> 30;
    x *= 0xbf58476d1ce4e5b9UL;
    x ^= x >> 27;
    x *= 0x94d049bb133111ebUL;
    x ^= x >> 31;
    return x;
}

// Read the 4-word chunk at canonical offset `off` (shard-mapped) and fold it into `state`.
uint64_t step_state(uint64_t state, uint64_t off) {
    uint shard = uint(off >> pc.shard_shift);
    uint64_t local = off & pc.shard_mask;
    Shard chunk = Shard(SHARDS.addr[shard] + local * 32UL);
    uint64_t h = state;
    h ^= chunk.words[0];
    h ^= chunk.words[1];
    h ^= chunk.words[2];
    h ^= chunk.words[3];
    return mix64(h);
}

void main() {
    uint base = gl_GlobalInvocationID.x * G; // first nonce offset this invocation owns

    uint64_t state[G];
    uint64_t off[G];
    bool live[G];

    // Seed G independent nonces. Inactive lanes (past the batch end) still run the walk with a
    // benign seed so the loop stays uniform; they just never record a winner.
    for (uint g = 0u; g < G; ++g) {
        uint o = base + g;
        live[g] = (o < pc.batch);
        uint64_t nonce = pc.start_nonce + uint64_t(o);
        uint64_t s = mix64(nonce ^ 0x4B65727978531UL);
        s = mix64(s ^ pc.timestamp);
        s = mix64(s ^ pc.p0);
        s = mix64(s ^ pc.p1);
        s = mix64(s ^ pc.p2);
        s = mix64(s ^ pc.p3);
        state[g] = s;
        off[g] = s % pc.n_chunks;
    }

    // Interleaved walk: each step issues G independent chunk reads before any dependency resolves,
    // so their latencies overlap instead of serializing.
    for (uint i = 0u; i < pc.k; ++i) {
        for (uint g = 0u; g < G; ++g) {
            state[g] = step_state(state[g], off[g]);
            off[g] = state[g] % pc.n_chunks;
        }
    }

    for (uint g = 0u; g < G; ++g) {
        if (!live[g]) {
            continue;
        }
        uint64_t o0 = mix64(state[g] ^ pc.p0 ^ 0x9E3779B97F4A7C15UL);
        uint64_t o1 = mix64(o0 ^ pc.p1 ^ 0xC2B2AE3D27D4EB4FUL);
        uint64_t o2 = mix64(o1 ^ pc.p2 ^ 0x165667B19E3779F9UL);
        uint64_t o3 = mix64(o2 ^ pc.p3 ^ 0xD6E8FEB86659FD93UL);
        bool le;
        if (o3 != pc.t3) { le = o3 < pc.t3; }
        else if (o2 != pc.t2) { le = o2 < pc.t2; }
        else if (o1 != pc.t1) { le = o1 < pc.t1; }
        else if (o0 != pc.t0) { le = o0 < pc.t0; }
        else { le = true; }
        if (le) {
            atomicMin(OUT.offset, base + g);
        }
    }
}
